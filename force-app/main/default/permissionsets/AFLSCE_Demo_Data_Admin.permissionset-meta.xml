<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Grants access to the AFLSCE Demo Data Starter Kit admin interface and all Apex controllers.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>AFLSCE Demo Data Admin</label>
    <classAccesses>
        <apexClass>DemoTerritoryController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>DemoAccountProviderController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>DemoContactPointController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>DemoScenarioController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <tabSettings>
        <tab>AFLSCE_Demo_Data</tab>
        <visibility>Visible</visibility>
    </tabSettings>
</PermissionSet>
